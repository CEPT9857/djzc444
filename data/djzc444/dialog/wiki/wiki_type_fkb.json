                    },
                    "lore": [
                        {
                            "translate": "djzc.sanlian3.desc",
                            "fallback": "更高 更快 更强",
                            "italic": false
                        }
                    ]
                }
            }
        },
        {
            "type": "item",
            "width": 100,
            "item": {
                "id": "crossbow",
