gamerule spawn_mobs true
#禁止自然生物生成
gamerule spawn_patrols true
#禁止巡逻队生成
gamerule minecraft:spawn_wandering_traders true
#禁止流浪商人生成
gamerule spawn_phantoms true
#禁止幻翼生成
gamerule spawn_monsters true
#禁止怪物生成
gamerule spawn_wardens true
#禁止监守者生成
gamerule mob_drops true
#禁止生物掉落物
gamerule fire_spread_radius_around_player 128
#禁止火焰扩散
gamerule spectators_generate_chunks true
#禁止旁观者生成区块

scoreboard players set boost 3 0
#在计分板中，表明已经关闭boost